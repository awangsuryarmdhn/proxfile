{
  "version": 2,
  "name": "antipro",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}

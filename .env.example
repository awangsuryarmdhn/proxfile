# --- SERVER CONFIGURATION ---
PORT=3000
NODE_ENV=production

# --- EMAIL CONFIGURATION (Required for Auto Appeal) ---
# Supported services: 'outlook', 'gmail', or leave blank for custom SMTP
SMTP_SERVICE=outlook
SMTP_USER=your-email@outlook.com
SMTP_PASS=your-app-password

# For Custom SMTP (If SMTP_SERVICE is blank)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587

# --- SCANNER CONFIGURATION ---
TIMEOUT=7000
CONCURRENCY=30

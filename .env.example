# --- SERVER CONFIGURATION ---
PORT=3000
NODE_ENV=production

# --- EMAIL CONFIGURATION (Required for Auto Appeal) ---
#
# SMTP_SERVICE options:
#   'outlook'  → Personal Outlook.com / Hotmail accounts (smtp-mail.outlook.com:587)
#                Prerequisite: use an App Password (generate one at
#                account.microsoft.com → Security → App passwords).
#                If two-step verification is disabled, your regular password works.
#   'office365' → Microsoft 365 / Office 365 business accounts (smtp.office365.com:587)
#                 Prerequisite: SMTP AUTH must be enabled for the mailbox in the
#                 Microsoft 365 admin centre (Users → Active users → Mail → Manage
#                 email apps → toggle "Authenticated SMTP").
#   'gmail'    → Gmail account (smtp.gmail.com:587)
#                Prerequisite: use an App Password (not your regular Google password).
#                Generate one at myaccount.google.com → Security → App passwords.
#   (blank)    → Custom SMTP — fill in SMTP_HOST / SMTP_PORT below instead.
#
SMTP_SERVICE=gmail
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# For Custom SMTP (only used when SMTP_SERVICE is blank)
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587

# --- SCANNER CONFIGURATION ---
TIMEOUT=7000
# --- TELEGRAM BOT (Zero Waste Webhooks) ---
TELEGRAM_BOT_TOKEN=your:bot_token_from_botfather
